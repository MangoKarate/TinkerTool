  "notes": [
    {
      "id": "n176",
      "x": 40,
      "y": 950,
      "w": 320,
      "text": "Wire flags: print one per label from Verified Wire Labels v30 — one flag per wire, at the hub / distribution / H1 end."
    },
    {
      "id": "n177",
      "x": 430,
      "y": 1000,
      "w": 340,
      "text": "Each eye signal meets at a soldered Y-splice: roughly 6in from Eye 1 and 6in from Eye 2 join, and a single pigtail carries the signal on to the Treedix. Only that pigtail gets a flag; the two eye legs do not."
    },
    {
      "id": "n178",
      "x": 1180,
      "y": 760,
      "w": 300,
      "text": "H1 position 6 stays physically empty: no terminal, no wire, no flag."
    },
    {
      "id": "n179",
      "x": 1440,
      "y": 320,
      "w": 300,
      "text": "470uF 16V across V+ and GND — striped negative lead to GND. Follow the PCA9685's printed PWM / V+ / GND order; servo lead colours are not universal."
    },
    {
      "id": "n180",
      "x": 1440,
      "y": 600,
      "w": 300,
      "text": "Speaker OUT− is not ground. Neither speaker lead may touch common ground."
    },
    {
      "id": "n181",
      "x": 430,
      "y": 40,
      "w": 320,
      "text": "microSD: use the pad identified as the 3.3V input, not the 5V pad. Leave the existing 10k card-detect pull-up in place."
    }
  ],
